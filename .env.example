# SF Open Data App Token (optional but raises rate limit from 1,000 to 1,000,000 requests/day)
# Get a free token at: https://data.sfgov.org/profile/app_tokens
VITE_SF_APP_TOKEN=

# Firebase Cloud Messaging VAPID key (for background push on locked phones)
# See README — FCM setup needed for true background notifications
VITE_FCM_VAPID_KEY=
